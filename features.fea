  pos [yehshape.fina.ii]'<-100 0 -100 0> [smallalef.replacement]'lookup shrink.space.2.cont.l1 [space]'  [hah.init]' ;

  
  pos [yehshape.fina.ii]' space'<-100 0 -100 0> [alef.isol]'<0 30 0 0> [wasla]' ;

} shrink.space.2.cont ;

lookup shrink.space.3 {

  feature inherited; 
  
  pos [/^endofaya/]'<-80 0 -80 0> space' [waw.isol]';
  pos [alef.fina.laf]' space'<-50 0 -50 0> [behshape.init]' [onedotdown]' [fatha]' ;
  pos [heh.fina.afterlam]' [twodotsup]' [fatha]' [space]'<-40 0 -40 0> [/^endofaya/]; 
  pos [smallwaw]'<-30 0 -30 0> /^space/' /^endofaya/;
  pos [yehshape.fina.ii]'<-50 0 -50 0> [smallalef.replacement]' /^space/' /^endofaya/;

} shrink.space.3 ;

