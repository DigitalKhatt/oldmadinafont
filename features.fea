  sub [meem.fina.ii]' [kasratanidgham]' space'lookup shrink.space.l2 /^endofaya/';
  

} shrink.space.with_marks ;

lookup shrink.space.adjustmarks {
  feature inherited; 

  pos [reh.isol]' [dammatanidgham]'<0 150 0 0> space' [/^endofaya/]' ;

} shrink.space.adjustmarks;

lookup shrink.space.2.cont {

  feature inherited; 
  

  lookup shrink.space.2.cont.l1 {              
    pos [smallalef.replacement] <0 200 0 0>;        
