  pos [heh.isol]' [twodotsup]' [kasratan]' [waqf.sad]'  space' [alef.isol]'<0 0 80 0> [hamzabelow]' [kasra]';
  pos [heh.isol]' [twodotsup]' [dammatanidgham]' space' [kaf.init.beforelam]'<0 0 50 0>;

} betweenspacekern;

