lookup shrink.gsub1 {

  feature inherited;

  lookup shrink.gsub1.l1 {
    sub lam.init by lam.init.beforemeem;
    sub meem.medi by meem.medi.afterlam;      		    
  } shrink.gsub1.l1; 

  lookup shrink.gsub1.l2 {
    sub fatha add -0.1 0;    
  } shrink.gsub1.l2;   

  lookup shrink.gsub1.l3 {
    sub seen.init by seen.init.beforemeem;
    sub meem.medi by meem.medi.afterseen;      		    
  } shrink.gsub1.l3; 

  sub [lam.init]'lookup shrink.gsub1.l1 [sukun fatha]'lookup shrink.gsub1.l2 [meem.medi]'lookup shrink.gsub1.l1 [fatha ]'lookup shrink.gsub1.l2;

  sub [lam.init]'lookup shrink.gsub1.l1 [sukun]' [meem.medi]'lookup shrink.gsub1.l1 [damma] [seen.medi] [sukun];

  sub [seen.init]'lookup shrink.gsub1.l3 [fatha]' [meem.medi]'lookup shrink.gsub1.l3 [kasra]' ;

} shrink.gsub1;

lookup shrink.gsub2 {

  feature inherited;

  #lookupflag IgnoreMarks ;
  #lookupflag UseMarkFilteringSet [@joinedmarks];
  lookupflag UseMarkFilteringSet [smallalef smallalef.joined hamzaabove.joined smallhighyeh  smallhighnoon smallhighwaw];

  lookup shrink.gsub2.l1 {    
    sub fehshape.init by fehshape.init.beforehah;
    sub hah.medi by hah.medi.afterfeh;	 	    
  } shrink.gsub2.l1; 

  lookup shrink.gsub2.l2 {       
    sub sad.init by sad.init.beforehah;	 
    sub hah.medi by hah.medi.aftersad;	    	    
  } shrink.gsub2.l2; 

  sub [lam.init]'lookup shrink.gsub1.l1 [sukun]' [meem.medi]'lookup shrink.gsub1.l1 [fatha]'lookup shrink.gsub1.l2;   

  sub [fehshape.init]'lookup shrink.gsub2.l1 [hah.medi]'lookup shrink.gsub2.l1;
  sub [sad.init]'lookup shrink.gsub2.l2 [hah.medi]'lookup shrink.gsub2.l2;

  lookup shrink.gsub2.l3 {       
    sub behshape.init by behshape.init.beforereh;
    sub reh.fina by reh.fina.afterbehshape;  	    
  } shrink.gsub2.l3; 

  sub (behshape.init reh.fina)'lookup shrink.gsub2.l3;

  lookup shrink.gsub2.l4 {
    sub kaf.medi  by kaf.medi.beforemeem;
    sub meem.fina.ii by meem.fina.afterkaf;
  } shrink.gsub2.l4;   

  sub (kaf.medi meem.fina.ii)'lookup shrink.gsub2.l4;

  lookup shrink.gsub2.l5 {
    sub lam.init  by lam.init.beforeseenmeem;
    sub seen.medi by seen.medi.betweenlammeem;
    sub meem.medi by meem.medi.afteralefseen;
  } shrink.gsub2.l5;

  sub [lam.init]'lookup shrink.gsub2.l5 [seen.medi]'lookup shrink.gsub2.l5 [meem.medi]'lookup shrink.gsub2.l5 [alef.fina] [hamza.isol];
  

} shrink.gsub2;

lookup shrink.gsub2.gpos {

  feature inherited;

  lookupflag IgnoreMarks ;

  pos [meem.medi.afteralefseen]' [alef.fina]'<0 -150 0 0>;

  pos [behshape.init.beforereh]' [reh.fina.afterbehshape]'<0 -50 0 0>;

} shrink.gsub2.gpos;

lookup shrink.gsub3 {

  feature inherited; 

  lookup shrink.gsub3.l1 {
    sub heh.init  by heh.init.beforemeem.ii;    
    sub meem.fina.ii by meem.fina.afterheh.ii;
    sub lam.medi by lam.medi.beforemeem;
    sub meem.fina.ii by meem.fina.afterlam;
  } shrink.gsub3.l1;

  sub [heh.init]'lookup shrink.gsub3.l1 [damma]' [meem.fina.ii]'lookup shrink.gsub3.l1 ;

  sub [lam.medi]'lookup shrink.gsub3.l1 [fatha]' [meem.fina.ii]'lookup shrink.gsub3.l1;

} shrink.gsub3;


lookup shrink.kern1 {

  feature inherited;

  lookup shrink.kern1.l1 {
    lookupflag IgnoreMarks ;
    pos cursive [noon.isol] <anchor 0 0> <anchor 0 0> ;
    pos cursive [waw.isol] <anchor 0 0> <anchor 0 0> ;
    pos cursive [reh.isol] <anchor 0 0> <anchor 0 0> ;
  } shrink.kern1.l1;

  lookup shrink.kern1.l2 {
    lookupflag IgnoreMarks ;
    pos cursive [dal.fina] <anchor 0 0> <anchor 0 0> ;
    pos cursive [alef.isol] <anchor 0 0> <anchor 0 0> ;    
  } shrink.kern1.l2;   

  pos [reh.isol] [damma] [waw.isol]'lookup shrink.kern1.l1 [noon.isol]'<0 100 -50 0> ;
  pos [waw.isol] [noon.isol]'lookup shrink.kern1.l1 [fatha]; 
  pos [reh.fina.afterseen]'<-70 0 -70 0>  [fatha]' [alef.isol] ;
  
  pos [reh.fina reh.fina.afterbehshape]' [kasra]' [qaf.isol]'<0 50 -100 0> [twodotsup]' [fatha]' ;
  
  
  pos [waw.fina]' [sukun]' [meem.isol.ii]'<0 0 -50 0> [damma]';
  
  pos [reh.fina]' [kasra]' [behshape.init]'<0 0 -100 0> [twodotsdown]' ;

  pos [dal.fina]' ([onedotup]?)' [fatha]' [alef.isol]'lookup shrink.kern1.l2; 

  pos [reh.isol]'<-50 0 -50 0> [kasra]' [behshape.init.beforenoon]' [twodotsdown]' [noon.fina.afterbeh]'<0 80 0 0> ;
  
  pos [alef.fina.lamalef]'<-100 0 -100 0> [hamzabelow]' [kasra]' [behshape.init.beforeseen]' [onedotup]';

  pos [reh.fina]'<-100 0 -100 0> [sukun]' [dal.isol]' [kasratanidgham]';

  pos [waw.fina]'<-50 0 -50 0>  [sukun]' [meem.isol.ii]' [fatha]' ;

  pos [waw.isol]'<-50 0 -50 0> [fatha]' [ain.init.finjani]' [onedotup]' [fatha]';

  #pos [alef.isol]'<-50 0 -50 0> [hamzaabove]' [fatha]' [noon.isol]';
